{
  "name": "etil-web",
  "version": "0.1.0",
  "description": "ETIL Browser REPL via WebAssembly",
  "type": "module",
  "scripts": {
    "dev": "esbuild web/src/main.ts --bundle --outdir=dist --servedir=web --serve=8080 --watch",
    "build": "esbuild web/src/main.ts --bundle --outdir=dist --minify --sourcemap",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["etil", "forth", "wasm", "repl"],
  "author": "ETIL-ORG",
  "license": "BSD-3-Clause",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
